# ═══════════════════════════════════════
# ScoreMyCV — Environment Variables
# Copy this to .env and fill in values
# ═══════════════════════════════════════

# Flask
FLASK_SECRET_KEY=your-super-secret-key-change-this
FLASK_DEBUG=False
APP_URL=https://yourdomain.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Groq AI
GROQ_API_KEY=your-groq-api-key

# JWT
JWT_SECRET_KEY=another-secret-key-change-this

# Mail (Gmail App Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=ScoreMyCV <your@gmail.com>

# Google OAuth (Supabase handles this — add in Supabase Auth settings)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
